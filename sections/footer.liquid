{% assign help_link = routes.root_url | append: '#about' %}

<footer class="site-footer" id="about">
  <div class="ovra-container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a class="footer-brand__logo" href="{{ routes.root_url }}">{{ settings.brand_name | default: 'ŌVRA' }}</a>
        <p class="footer-brand__tagline">{{ settings.brand_tagline | default: 'Wear The Difference' }}</p>
        <p class="footer-copy">
          Premium streetwear with editorial restraint, oversized confidence, and a sharp after-dark finish.
        </p>
        <div class="footer-social">
          <a href="{{ settings.social_instagram | default: '#' }}" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
              <rect x="3.5" y="3.5" width="17" height="17" rx="5"></rect>
              <circle cx="12" cy="12" r="3.7"></circle>
              <circle cx="17.2" cy="6.8" r="1"></circle>
            </svg>
          </a>
          <a href="{{ settings.social_twitter | default: '#' }}" aria-label="Twitter">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
              <path d="M22 5.8c-.7.3-1.5.5-2.3.7a4 4 0 0 0 1.8-2.2 8.3 8.3 0 0 1-2.6 1A4 4 0 0 0 12 8.1c0 .3 0 .7.1 1A11.3 11.3 0 0 1 3.8 4.9a4 4 0 0 0 1.2 5.4c-.6 0-1.2-.2-1.7-.5 0 1.9 1.3 3.5 3.2 3.9-.4.1-.8.2-1.2.2-.3 0-.6 0-.9-.1.6 1.7 2.1 2.9 4 2.9A8.1 8.1 0 0 1 2 18.4 11.4 11.4 0 0 0 8.2 20c7.4 0 11.5-6.1 11.5-11.4v-.5c.8-.5 1.6-1.3 2.3-2.3Z"></path>
            </svg>
          </a>
          <a href="{{ settings.social_pinterest | default: '#' }}" aria-label="Pinterest">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
              <path d="M12 3.5c-4.8 0-7.3 3.4-7.3 7 0 2.1 1.1 4.6 2.8 5.4.3.1.4.1.5-.2l.5-2c.1-.2 0-.3-.1-.5-.4-.5-.8-1.4-.8-2.5 0-3.2 2.4-6 6.2-6 3.4 0 5.3 2.1 5.3 4.8 0 3.6-1.6 6.6-4 6.6-1.3 0-2.2-1.1-1.9-2.4.4-1.6 1.1-3.4 1.1-4.6 0-1.1-.6-2-1.8-2-1.4 0-2.5 1.4-2.5 3.3 0 1.2.4 2 .4 2l-1.5 6.2c-.4 1.7-.1 3.8 0 4.4.1.2.2.2.3.1.2-.3 1.8-2.3 2.3-4.1l.7-2.6c.4.8 1.5 1.5 2.6 1.5 3.5 0 5.8-3.2 5.8-7.4 0-3.1-2.6-6-6.6-6Z"></path>
            </svg>
          </a>
        </div>
      </div>

      <div>
        <h3 class="footer-title">{{ 'footer.shop_heading' | t }}</h3>
        <div class="footer-links">
          <a href="{{ routes.root_url }}#new-in">New In</a>
          <a href="{{ routes.root_url }}#featured-products">Latest Drops</a>
          <a href="{{ routes.root_url }}#lookbook">Lookbook</a>
          <a href="{{ routes.root_url }}#sale-edit">Sale Edit</a>
        </div>
      </div>

      <div>
        <h3 class="footer-title">{{ 'footer.help_heading' | t }}</h3>
        <div class="footer-links">
          <a href="{{ routes.cart_url }}">Shipping & Returns</a>
          <a href="{{ routes.root_url }}#featured-products">Size Guide</a>
          <a href="{{ routes.cart_url }}">Track Order</a>
          <a href="{{ help_link }}">Contact</a>
        </div>
      </div>

      <div>
        <h3 class="footer-title">{{ 'footer.newsletter_heading' | t }}</h3>
        {% form 'customer', id: 'FooterNewsletterForm', class: 'newsletter-form js-newsletter-form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <label class="visually-hidden" for="FooterNewsletterEmail">{{ 'footer.newsletter_heading' | t }}</label>
          <div class="newsletter-form__controls">
            <input
              id="FooterNewsletterEmail"
              type="email"
              name="contact[email]"
              placeholder="{{ 'footer.newsletter_placeholder' | t }}"
              required
            >
            <button class="button" type="submit">{{ 'footer.newsletter_button' | t }}</button>
          </div>
          <div class="newsletter-feedback" data-newsletter-feedback>
            {% if form.posted_successfully? %}You’re in. Expect early access to the next drop.{% endif %}
          </div>
        {% endform %}
        <p class="newsletter-note">Subscriber access unlocks first looks, limited restocks, and private drop alerts.</p>
      </div>
    </div>

    <div class="footer-bottom">
      <span>{{ 'footer.copyright' | t }}</span>
      <span>{{ 'footer.made_with' | t }}</span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
